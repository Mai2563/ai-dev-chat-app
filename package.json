{
  "name": "ai-dev-chat-app",
  "version": "1.0.0",
  "description": "AI-powered real-time chat system for developers",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "openai": "^4.28.0",
    "socket.io": "^4.7.4"
  }
}
